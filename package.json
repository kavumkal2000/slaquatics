{
  "name": "shoreline-aquatics-ops",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:legacy": "node legacy/render/server.js",
    "check": "node scripts/validate.js && npm run test:migration",
    "smoke": "node scripts/smoke.js",
    "ops-state:transfer": "node scripts/transfer-ops-state.mjs",
    "media:publish": "node scripts/publish-media-r2.mjs",
    "media:bucket:create:dev": "wrangler r2 bucket create slaquatics-media-development",
    "media:bucket:create:prod": "wrangler r2 bucket create slaquatics-media-production",
    "media:domain:dev": "wrangler r2 bucket domain add slaquatics-media-development --domain cdn.dev.slaquatics.com --zone-id $CLOUDFLARE_ZONE_ID",
    "media:domain:prod": "wrangler r2 bucket domain add slaquatics-media-production --domain cdn.slaquatics.com --zone-id $CLOUDFLARE_ZONE_ID",
    "cms:seed-owner": "node scripts/seed-cms-owner.mjs",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy:dev": "opennextjs-cloudflare deploy --env development",
    "cf:deploy:prod": "opennextjs-cloudflare deploy --env production",
    "test:migration": "node --experimental-strip-types --test tests/migration/*.test.mjs"
  },
  "dependencies": {
    "next": "^16.2.9",
    "pg": "^8.16.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^19.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
