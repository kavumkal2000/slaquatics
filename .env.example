# Local-only placeholders. Set Cloudflare Worker secrets/vars separately for
# development and production; do not copy real secrets into this file.

NODE_ENV=development
PUBLIC_SITE_URL=https://slaquatics.com
PUBLIC_MEDIA_BASE_URL=https://cdn.dev.slaquatics.com
PUBLIC_CORS_ALLOWED_ORIGINS=https://slaquatics.com,https://www.slaquatics.com
REQUIRE_SERVER_STORE=false

SESSION_SECRET=replace-with-long-random-local-secret
OPS_DEV_USERNAME=developer
OPS_DEV_PASSWORD=replace-with-local-dev-password
OPS_OWNER_USERNAME=owner
OPS_OWNER_PASSWORD_HASH=pbkdf2-sha256:210000:replace-with-salt:replace-with-hash
OPS_EMPLOYEE_USERNAME=hugoprado
OPS_EMPLOYEE_PASSWORD=replace-with-employee-password
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
OWNER_PASSKEY_GRACE_SECONDS=604800

STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

RESEND_API_KEY=re_replace
RESEND_FROM_EMAIL=bookings@example.com
RESEND_FROM_NAME=Shoreline Aquatics
RESEND_REPLY_TO_EMAIL=bookings@example.com
OWNER_UPDATE_EMAILS=owner@example.com
BOOKING_ALERT_EMAILS=owner@example.com

OWNER_WEEKLY_DIGEST_ENABLED=true
OWNER_WEEKLY_DIGEST_TIMEZONE=America/Chicago
OWNER_WEEKLY_DIGEST_WEEKDAY=1
OWNER_WEEKLY_DIGEST_HOUR=9
OWNER_WEEKLY_DIGEST_MINUTE=0
OWNER_WEEKLY_CRON_SECRET=replace-with-long-random-cron-secret

ALLOW_DOUBLE_BOOKING=true
GOOGLE_REVIEW_URL=https://example.com/review

TWILIO_ACCOUNT_SID=AC_replace
TWILIO_AUTH_TOKEN=replace-with-token
TWILIO_FROM_NUMBER=+10000000000

SOCIAL_AUTOMATION_WEBHOOK_URL=https://example.com/social
SOCIAL_AUTOMATION_WEBHOOK_SECRET=replace-with-webhook-secret
SOCIAL_FACEBOOK_WEBHOOK_URL=
SOCIAL_INSTAGRAM_WEBHOOK_URL=
SOCIAL_X_WEBHOOK_URL=
SOCIAL_TIKTOK_WEBHOOK_URL=
